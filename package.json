{
  "name": "glean-test-flow",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "1:setup": "npx tsx src/1-setup-datasource.ts",
    "2:index": "npx tsx src/2-index-documents.ts",
    "3:check": "npx tsx src/3-check-status.ts",
    "4:search": "npx tsx src/4-search.ts",
    "dev": "concurrently --raw \"npx tsx watch server/index.ts\" \"cd app && npx vite\"",
    "dev:server": "npx tsx watch server/index.ts",
    "dev:app": "cd app && npx vite"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "csv-parse": "^5.5.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^22.0.0",
    "concurrently": "^8.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
